{
  "version": 3,
  "configurePresets": [
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/cmake-build-mingw",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "C:/Program Files/JetBrains/CLion 2025.3.3/bin/mingw/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/Program Files/JetBrains/CLion 2025.3.3/bin/mingw/bin/g++.exe"
      },
      "environment": {
        "PATH": "C:/Program Files/JetBrains/CLion 2025.3.3/bin/mingw/bin;$penv{PATH}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "jobs": 4
    }
  ],
  "testPresets": [
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
